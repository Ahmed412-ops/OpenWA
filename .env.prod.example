# =============================================================================
# OpenWA Production — Ahmed's Hardened Environment Configuration
# =============================================================================

# --- Core ---
NODE_ENV=production
PORT=2785
LOG_LEVEL=info

# Public URLs (startup banner)
BASE_URL=https://api.openwa.algo-prd.com
DASHBOARD_URL=https://openwa.algo-prd.com

# CORS (ممنوع أي دومين غريب يكلم الـ API)
CORS_ORIGINS=https://openwa.algo-prd.com,https://api.openwa.algo-prd.com

# --- Traefik Configuration (ربط التوجيه والـ SSL الحقيقي) ---
TRAEFIK_API_HOST=api.openwa.algo-prd.com
TRAEFIK_DASHBOARD_HOST=openwa.algo-prd.com
TRAEFIK_CERT_RESOLVER=mytlschallenge
TRAEFIK_NETWORK=n8n_default

# --- PostgreSQL Configuration ---
DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=owa_admin_user
DATABASE_PASSWORD=Dh9_xK2_mPq7_vSt91_SecureDb
DATABASE_NAME=openwa_prod

POSTGRES_USER=owa_admin_user
POSTGRES_PASSWORD=Dh9_xK2_mPq7_vSt91_SecureDb
POSTGRES_DB=openwa_prod

# ⚠️ مهم جداً: أول تشغيل فقط خليه true عشان يكريت الجداول، بعد ما يشتغل رده false
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# --- Redis Configuration ---
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Zx4_rW8_bYp2_qLk90_SecureRedis
QUEUE_ENABLED=false

# --- WhatsApp engine ---
ENGINE_TYPE=whatsapp-web.js
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# --- Storage ---
STORAGE_TYPE=local

# --- Webhooks ---
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# --- Rate limiting ---
RATE_LIMIT_SHORT_TTL=1000
RATE_LIMIT_SHORT_LIMIT=10
RATE_LIMIT_MEDIUM_TTL=60000
RATE_LIMIT_MEDIUM_LIMIT=100
RATE_LIMIT_LONG_TTL=3600000
RATE_LIMIT_LONG_LIMIT=1000

# --- Security hardening ---
PLUGINS_ENABLED=false

# 🔑 ملحوظة الـ API Key:
